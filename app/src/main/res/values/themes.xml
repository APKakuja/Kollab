<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- 🎨 Tema base (COMPATIBLE con AppCompatActivity) -->
    <style name="Base.Theme.Kollab" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Personaliza colores si quieres -->
    </style>

    <!-- 🎯 Tema principal de la app -->
    <style name="Theme.Kollab" parent="Base.Theme.Kollab" />

    <!-- 🚀 Splash Screen (CORREGIDO) -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">

        <item name="windowSplashScreenBackground">@color/white</item>

        <item name="postSplashScreenTheme">@style/Theme.Kollab</item>

        <!-- ⚠️ ICONO: asegúrate que exista -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/animated_logo</item>

    </style>

</resources>